# Carly Customer Service Agent — Environment Variables
# Version: v0.2.0
#
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to the repository.

# Retell
RETELL_API_KEY=
RETELL_AGENT_ID=

# n8n
N8N_WEBHOOK_URL=

# LLM for post-conversation extraction
# Use one of the following:
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=

# Google Sheets
GOOGLE_SHEETS_ID=

# WhatsApp alerting
WHATSAPP_API_URL=
WHATSAPP_RECIPIENT=

# Booking page URL (provided to customers by Carly)
BOOKING_PAGE_URL=https://www.cookinfiesta.com/book
